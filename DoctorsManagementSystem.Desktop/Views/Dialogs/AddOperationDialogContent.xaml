<UserControl
    x:Class="DoctorsManagementSystem.Desktop.Views.Dialogs.AddOperationDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="clr-namespace:DoctorsManagementSystem.Desktop.Infrastructure.Converters"
    mc:Ignorable="d"
    d:DesignWidth="420">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
        <StackPanel Width="420">

            <TextBlock Text="New Medical Operation" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8" />

            <TextBlock Text="Operation Name" FontSize="12" Opacity="0.7" Margin="0,8,0,4" />
            <ui:TextBox PlaceholderText="e.g. Cataract Surgery" Text="{Binding OperationName, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Doctor's Notes" FontSize="12" Opacity="0.7" Margin="0,8,0,4" />
            <ui:TextBox
                PlaceholderText="Optional notes"
                Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="80" />

            <TextBlock Text="Operation Cost" FontSize="12" Opacity="0.7" Margin="0,8,0,4" />
            <ui:TextBox Text="{Binding OperationCost, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Session Date" FontSize="12" Opacity="0.7" Margin="0,8,0,4" />
            <DatePicker SelectedDate="{Binding SessionDate}" />

            <TextBlock
                Text="{Binding ErrorMessage}"
                Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                TextWrapping="Wrap"
                Margin="0,12,0,0"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:ProgressRing
                    Grid.Column="0"
                    IsIndeterminate="True"
                    Width="20" Height="20"
                    HorizontalAlignment="Left"
                    Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibilityConverter}}" />

                <ui:Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}" Margin="0,0,8,0" Appearance="Secondary" />
                <ui:Button Grid.Column="2" Content="Save Operation" Command="{Binding SaveCommand}" Appearance="Primary" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>