<Page
    x:Class="DoctorsManagementSystem.Desktop.Views.Pages.PatientDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="clr-namespace:DoctorsManagementSystem.Desktop.Infrastructure.Converters"
    mc:Ignorable="d"
    d:DesignHeight="650" d:DesignWidth="1000"
    Title="PatientDetailsPage">

    <Page.Resources>
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:Button
            Grid.Row="0"
            Content="Back to Patients"
            Icon="{ui:SymbolIcon ArrowLeft24}"
            Command="{Binding ViewModel.GoBackCommand}"
            Appearance="Secondary"
            HorizontalAlignment="Left"
            Margin="0,0,0,16" />

        <Grid
            Grid.Row="1"
            Margin="0,0,0,16"
            Visibility="{Binding ViewModel.State, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Loaded}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding ViewModel.Patient.PatientName}" FontSize="28" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <ui:SymbolIcon Symbol="Phone24" FontSize="14" Opacity="0.6" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ViewModel.Patient.PatientPhone}" Margin="6,0,16,0" Opacity="0.75" VerticalAlignment="Center" />
                    <ui:SymbolIcon Symbol="Mail24" FontSize="14" Opacity="0.6" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ViewModel.Patient.PatientEmail}" Margin="6,0,16,0" Opacity="0.75" VerticalAlignment="Center" />
                    <ui:SymbolIcon Symbol="Money24" FontSize="14" Opacity="0.6" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ViewModel.Patient.TotalBill, StringFormat={}{0:C}}" Margin="6,0,0,0" Opacity="0.75" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <ui:Button
                Grid.Column="1"
                Content="Add New Prescription"
                Icon="{ui:SymbolIcon AddCircle24}"
                Command="{Binding ViewModel.OpenAddPrescriptionDialogCommand}"
                Appearance="Primary"
                VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="2">

            <StackPanel
                Visibility="{Binding ViewModel.State, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Loading}"
                HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="42" Height="42" />
                <TextBlock Text="Loading patient…" Margin="0,12,0,0" Opacity="0.7" HorizontalAlignment="Center" />
            </StackPanel>

            <ui:Card
                Visibility="{Binding ViewModel.State, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Error}"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" MaxWidth="420">
                <StackPanel HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="32" HorizontalAlignment="Center" />
                    <TextBlock Text="Couldn't load this patient" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,4" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding ViewModel.ErrorMessage}" TextWrapping="Wrap" TextAlignment="Center" Opacity="0.75" />
                    <ui:Button Content="Try Again" Command="{Binding ViewModel.LoadPatientCommand}" Margin="0,16,0,0" HorizontalAlignment="Center" Appearance="Primary" />
                </StackPanel>
            </ui:Card>

            <Border
                Visibility="{Binding ViewModel.State, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Loaded}"
                CornerRadius="8"
                BorderThickness="1">

                <ui:DataGrid
                    ItemsSource="{Binding ViewModel.Prescriptions}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    RowHeight="44"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    Padding="4">
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn Header="Surgery / Procedure" Binding="{Binding SurgeryName}" Width="*" />
                        <DataGridTextColumn Header="Session Date" Binding="{Binding SessionDate, StringFormat=d}" Width="140" />
                        <DataGridTextColumn Header="Bill" Binding="{Binding SurgeryBill, StringFormat={}{0:C}}" Width="120" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding SurgeryNotes}" Width="250" />
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>